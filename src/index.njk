---
permalink: /index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wavelength</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="icon" href="./assets/icon-noborder.png">
    <script src="https://cdn.counter.dev/script.js" data-id="3a53e261-dd9c-4c39-9e87-9d97f844ae7c" data-utcoffset="-8"></script>
</head>
<body>
    <div class="window">
        <div class="title-bar">
            <img src="assets/icon-noborder.png" alt="logo" class="title-icon">
            <span>WAVELENGTH.EXE</span>
            <div class="window-buttons">
                <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ">
                  <button>hi</button>
                </a>
                <button>-</button>
                <button>□</button>
                <button>X</button>
            </div>
        </div>

        <nav class="tabs">
            <button class="tab active" onclick="switchTab('home', event)">[ home ]</button>
            <button class="tab" onclick="switchTab('games', event)">[ games ]</button>
            <button class="tab" onclick="switchTab('chat', event)">[ chat ]</button>
          <button class="tab" onclick="switchTab('users', event)">[ users ]</button>
            <button class="tab" onclick="switchTab('shop', event)">[ shop ]</button>
            <button class="tab" onclick="switchTab('credits', event)">[ credits ]</button>
        </nav>

        <div class="content">

            <!-- HOME -->
            <div id="tab-home" class="tab-panel active">
              <div class="home-layout">
                  <div class="panel">
                      <div class="panel-header">&#9670; Welcome</div>
                      <div class="panel-body">
                          <img src="assets/png/logo-cropped.png" class="welcome-banner" alt="Wavelength">
                          <div class="welcome-text">
                              <p>Welcome to Wavelength, where all the different types of game are combined into one website for your absolute best experience on the web!
                                Check out the chat to chat with other users and suggest games to add to the site! (the team takes suggestions every now and then)
                              </p>
                              <p>This website is open source, so feel free to contribute for anything we don't have!<p>
                              <a href="https://github.com/ki-krpto/Wavelength" target="_blank"> <img src="./assets/badges/github.png"></a>
                          </div>
                      </div>
                  </div>
                  <div class="panel">
                      <div class="panel-header">&#9670; Changelog</div>
                      <div class="panel-body">
                          <div class="changelog">
  <div class="log-entry">
                            <div class="log-date">April 10th, 2026 - 3:08pm</div>
                            <div class="log-title">added user accounts</div>
                            <div class="log-desc">y'all can login and chat with your own accounts! <br> any vulgar account names will be deleted and by default you will be in as a guest, no account linked <br> otherwise have fun! ~ aj</div>
                            <span class="tag tag-new">new</span>
                          </div>
                            <div class="log-entry">
                            <div class="log-date">April 10th, 2026 - 12:27pm</div>
                            <div class="log-title">make game buttons bigger</div>
                            <div class="log-desc">some of y'all don't know how to read so the buttons to make the games open in fullscreen are *bigger* now ~ aj</div>
                            <span class="tag tag-fix">fix</span>
                          </div>
                            <div class="log-entry">
                            <div class="log-date">April 9, 2026</div>
                            <div class="log-title">Fixed chat/added moderation</div>
                            <div class="log-desc">So turns out yall like bad words too much so there banned now ~ Itz_Kire</div>
                            <span class="tag tag-fix">Fix</span>
                          </div>
                             <div class="log-entry">
                                  <div class="log-date">April 6, 2026</div>
                                  <div class="log-title">added cdn switch</div>
                                  <div class="log-desc">githack gets blocked at some schools so we have multiple cdn's to fetch from! ~ aj</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                            <div class="log-entry">
                                  <div class="log-date">April 5, 2026</div>
                                  <div class="log-title">added more ports</div>
                                  <div class="log-desc">yeah uh some more web ports are on the site, go have fun - aj</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                              <div class="log-entry">
                                  <div class="log-date">April 4, 2026</div>
                                  <div class="log-title">Added: Shop</div>
                                  <div class="log-desc">There is now a shop, albeit its not a shop, and it doesn't work yet</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                              <div class="log-entry">
                                    <div class="log-date">April 3, 2026</div>
                                  <div class="log-title">Added: GAMES</div>
                                  <div class="log-desc">Play your favorite games on wavelength!</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
            </div>

            <!-- GAMES -->
            <div id="tab-games" class="tab-panel">

              <!-- List View -->
              <div id="games-list-view">
                <div class="games-controls">
                  <div class="games-filters">
                    <button class="games-filter-btn active" data-filter="all">All</button>
                    <button class="games-filter-btn" data-filter="html">HTML5</button>
                    <button class="games-filter-btn" data-filter="ruffle">Flash</button>
                    <button class="games-filter-btn" data-filter="webPorts">Web Ports</button>
                  </div>
                  <div class="games-search-row">
                    <input type="search" id="games-search" class="games-search-input" placeholder="Search games..." />
                    <select id="games-sort" class="games-sort-select">
                      <option value="alpha-asc">A → Z</option>
                      <option value="alpha-desc">Z → A</option>
                    </select>
                  </div>
                </div>
                <div id="games-grid" class="games-grid">
                  <div id="games-sentinel" class="games-sentinel"></div>
                </div>
                <div id="games-status" class="games-status"></div>
              </div>

              <!-- Play View -->
              <div id="games-play-view" style="display:none;">
                <button class="back-btn win-btn" onclick="closeGame()">back</button>

                <!-- CDN SWITCHER — top of play view -->
                <div class="cdn-switcher-row">
                  <span class="cdn-switcher-row-label">CDN:</span>
                  <div id="cdn-switcher"></div>
                  <span class="cdn-indicator-wrap">active: <span id="cdn-indicator">Statically</span></span>
                </div>

                <div class="play-view-inner">
                  <div class="iframe-container">
                    <iframe id="game-iframe" class="gameframe" allowfullscreen
                      sandbox="allow-scripts allow-same-origin allow-forms allow-pointer-lock allow-top-navigation"></iframe>
                  </div>
                </div>

                <!-- IFRAME BUTTONS — bottom of play view -->
                <div class="iframe-buttons">
                  <button class="win-btn" onclick="openCloaked()">fullscreen (new tab)</button>
                  <button class="win-btn" onclick="credits()">game credits</button>
                </div>
              </div>

            </div>

            <!-- CHAT -->
            <div id="tab-chat" class="tab-panel">

              <!-- USERNAME MODAL -->
              <div id="username-modal" class="modal-overlay" style="display:none;">
                <div class="modal-box">
                  <button class="modal-close-btn" onclick="closeUsernameModal()" aria-label="Close username dialog">x</button>
                  <div class="panel-header">&#9670; Join Chat</div>
                  <div class="panel-body" style="padding:12px;">
                    <p style="font-size:12px;margin-bottom:8px;">Choose a username:</p>
                    <input id="username-input" class="chat-input-field" type="text" maxlength="20" placeholder="your_name_here..."
                      onkeydown="if(event.key==='Enter')joinChat()">
                    <div id="username-error" style="color:#ff6b6b;font-size:11px;min-height:16px;margin-top:4px;"></div>
                    <div style="margin-top:8px;">
                      <button class="win-btn" onclick="joinChat()">[ JOIN ]</button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- CHAT UI -->
              <div id="chat-ui" style="display:none;">
                <div class="panel">
                  <div class="panel-header">
                    &#9670; Chat &nbsp;<span id="chat-user-label" style="font-weight:normal;font-size:10px;opacity:0.85;"></span>
                    <span id="chat-link-status" style="font-weight:normal;font-size:10px;opacity:0.85;margin-left:8px;"></span>
                    <button id="chat-link-btn" onclick="linkChatToAccount()" class="win-btn" style="display:none;font-size:9px; margin-left:10px; padding: 2px 5px;">[ LINK ACCOUNT ]</button>
                    <button onclick="changeUsername()" class="win-btn" style="font-size:9px; margin-left:10px; padding: 2px 5px;">[ CHANGE NAME ]</button>
                  </div>
                  <div class="panel-body" style="padding:0;display:flex;flex-direction:column;height:68vh;">
                    <div id="chat-messages" class="chat-messages"></div>
                    <div class="chat-footer">
                      <input id="chat-msg-input" class="chat-input-field" type="text" maxlength="500"
                        placeholder="type a message and press Enter..."
                        onkeydown="if(event.key==='Enter')sendMessage()">
                      <button class="win-btn" onclick="sendMessage()">[ SEND ]</button>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- USERS -->
            <div id="tab-users" class="tab-panel">
              <div class="users-layout">
                <div class="panel">
                  <div class="panel-header">&#9670; Account</div>
                  <div class="panel-body users-auth-body">
                    <div id="users-auth-status" class="users-auth-status">Not logged in.</div>

                    <div id="users-auth-message" class="users-auth-message"></div>

                    <div id="users-auth-forms">
                      <div class="users-auth-group">
                        <label for="users-register-name">Username</label>
                        <input id="users-register-name" class="chat-input-field" type="text" maxlength="24" placeholder="your_name_here...">
                      </div>
                      <div class="users-auth-group">
                        <label for="users-register-password">Password</label>
                        <input id="users-register-password" class="chat-input-field" type="password" maxlength="72" placeholder="at least 6 characters">
                      </div>
                      <div class="users-auth-actions">
                        <button class="win-btn" onclick="registerUser()">[ REGISTER ]</button>
                        <button class="win-btn" onclick="loginUser()">[ LOGIN ]</button>
                      </div>
                    </div>

                    <div id="users-auth-logged-in" style="display:none;">
                      <div class="users-auth-hello" id="users-auth-hello"></div>
                      <button class="win-btn" onclick="logoutUser()">[ LOG OUT ]</button>
                    </div>
                  </div>
                </div>

                <div class="panel">
                  <div class="panel-header">&#9670; Registered Users</div>
                  <div class="panel-body">
                    <div id="users-list-status" class="users-list-status">Loading users...</div>
                    <div id="users-list" class="users-list"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- SHOP -->
            <div id="tab-shop" class="tab-panel">
              <div class="panel">
                <div class="panel-header">&#9670; Shop</div>
                <div class="panel-body shop-body">
                  <div class="shop-text">
                    <p>Wavelength will always be free to play.</p>
                    <p>If you wish to support us, feel free to donate<br>to our side project Pydra!</p>
                    <p>if you wish to donate using crypto, please email<br><span class="shop-xmr">support@pydra.dev</span>.</p>
                  </div>
                  <div class="shop-logo-wrap">
                    <a href="https://hcb.hackclub.com/donations/start/pydra" target="_blank">
                      <img src="https://pydra.dev/favicon.png" alt="Pydra" class="shop-pydra-logo">
                      <div class="shop-logo-label">click on me!</div>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- CREDITS -->
            <div id="tab-credits" class="tab-panel">
              <div class="credits-title">~ credits ~</div>
              <div class="credits-section">
                  <div class="section-header">Main Developers</div>
                  <div class="credit-grid">
                    <a href="https://github.com/ajtabjs" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">aj</span></div>
                    </a>
                    <a href="https://github.com/ThatOnePers0n" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">ThatOnePers0n</span></div>
                    </a>
                    <a href="https://github.com/ki-krpto" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">its_kirè</span></div>
                    </a>
                    <a href="https://github.com/MinoDab492" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">MinoDab492</span></div>
                    </a>
                  </div>
              </div>
              <hr class="credits-divider">
              <div class="credits-section">
                  <div class="section-header">Game Sources</div>
                  <div class="credit-grid">
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">3kh0</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">Armor Games</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">BinBashBanana</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">John Cooney/jmtb02</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">Kongregate</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">Radon Games</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">The Eagle Team</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">ThatOnePers0n</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">breadbb/genizy</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">truffled.lol</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">sky at selenite.cc</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">National Porting Association/webport.ing</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">gays dot' studio</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">98corbins</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">wasm com</span></div>
                  </div>
              </div>
            </div>

        </div>
    </div>

    <!-- GAME CREDITS MODAL -->
    <div id="game-credits-modal" class="modal-overlay" style="display:none;">
      <div class="modal-box">
        <div class="panel-header">&#9670; Game Credits</div>
        <div class="panel-body" style="padding:12px;">
          <div id="game-credits-content" style="font-size:12px;line-height:1.6;max-height:400px;overflow-y:auto;">
            <p><strong>Game Sources:</strong></p>
            <p>3kh0<br>Armor Games<br>olyb/BinBashBanana<br>John Cooney/jmtb02<br>Kongregate<br>Radon Games<br>The Eagle Team<br>ThatOnePers0n<br>genizy/breadbb<br>truffled.lol<br>sky at selenite.cc<br>National Porting Association/webport.ing<br>gays dot' studio<br>bog/aukak<br>98corbins<br>wasm.com</p>
          </div>
          <div style="margin-top:12px;text-align:center;">
            <button class="win-btn" onclick="closeCreditsModal()">[ CLOSE ]</button>
          </div>
        </div>
      </div>
    </div>

    {# ═══════════════════════════════════════════════════════════════════
       ELEVENTY INJECTS GAME DATA HERE AT BUILD TIME
       Edit _data/htmlGames.json, ruffleGames.json, or webPorts.json to add games!
       Drop jsdelivrUrls.json and githackUrls.json in _data/ too.
       ═══════════════════════════════════════════════════════════════════ #}
    <script>
      window.__BASE_URLS__     = {{ statically | dump | safe }};
      window.__JSDELIVR_URLS__ = {{ jsdelivr | dump | safe }};
      window.__GITHACK_URLS__  = {{ githack | dump | safe }};
      window.__CREDITS_MAPPING__ = {{ creditsMapping | dump | safe }};
      window.__GAMES_DATA__ = [
        {% for g in htmlGames %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "html"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
        {% for g in ruffleGames %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "ruffle"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
        {% for g in webPorts %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "webPorts"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
      ];
    </script>

    <script src="games-loader.js"></script>
    <script src="site.js" type="module"></script>

</body>
</html>
