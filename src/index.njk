                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">John Cooney/jmtb02</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">Kongregate</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">Radon Games</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">The Eagle Team</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">ThatOnePers0n</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">breadbb/genizy</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">truffled.lol</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">sky at selenite.cc</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">National Porting Association/webport.ing</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">gays dot' studio</span></div>
                      <div class="credit-entry"><span class="dot dot-blue"></span><span class="name-blue">98corbins</span></div>
