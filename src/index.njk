              <div class="credits-section">
                  <div class="section-header">Main Developers</div>
                  <div class="credit-grid">
                    <a href="https://github.com/ajtabjs" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">aj</span></div>
                    </a>
                    <a href="https://github.com/ThatOnePers0n" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">ThatOnePers0n</span></div>
                    </a>
                    <a href="https://github.com/ki-krpto" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">its_kirè</span></div>
                    </a>
                    <a href="https://github.com/MinoDab492" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">MinoDab492</span></div>
                    </a>
                  </div>
              </div>
              <hr class="credits-divider">
              <div class="credits-section">
