permalink: /index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wavelength</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="icon" href="./assets/icon-noborder.png">
    <script src="https://cdn.counter.dev/script.js" data-id="3a53e261-dd9c-4c39-9e87-9d97f844ae7c" data-utcoffset="-8"></script>
</head>
<body>
    <div class="window">
        <div class="title-bar">
            <img src="assets/icon-noborder.png" alt="logo" class="title-icon">
            <span>WAVELENGTH.EXE</span>
            <div class="window-buttons">
                <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ">
                  <button>hi</button>
                </a>
                <button>-</button>
                <button>□</button>
                <button>X</button>
            </div>
        </div>

        <nav class="tabs">
            <button class="tab active" data-tab="home" onclick="switchTab('home', event)">[ home ]</button>
            <button class="tab" data-tab="games" onclick="switchTab('games', event)">[ games ]</button>
            <button class="tab" data-tab="chat" onclick="switchTab('chat', event)">[ chat ]</button>
            <button class="tab" data-tab="users" onclick="switchTab('users', event)">[ users ]</button>
            <button class="tab" data-tab="profile" onclick="switchTab('profile', event)">[ profile ]</button>
            <button class="tab" data-tab="shop" onclick="switchTab('shop', event)">[ shop ]</button>
            <button class="tab" data-tab="credits" onclick="switchTab('credits', event)">[ credits ]</button>
        </nav>

        <div class="content">

            <div id="tab-home" class="tab-panel active">
              <div class="home-layout">
                  <div class="panel">
                      <div class="panel-header">&#9670; Welcome</div>
                      <div class="panel-body">
                          <img src="assets/png/logo-cropped.png" class="welcome-banner" alt="Wavelength">
                          <div class="welcome-text">
                              <p>Welcome to Wavelength, where all the different types of game are combined into one website for your absolute best experience on the web!
                                Check out the chat to chat with other users and suggest games to add to the site! (the team takes suggestions every now and then)
                              </p>
                              <p>This website is open source, so feel free to contribute for anything we don't have!<p>
                              <a href="https://github.com/ki-krpto/Wavelength" target="_blank"> <img src="./assets/buttons/github.png"></a>
                              <a href="https://discord.gg/Yav59M7Hfn" target="_blank"><img src="./assets/buttons/discord.png"></a>
                          </div>
                      </div>
                      
                  </div>
                  <div class="panel">
                      <div class="panel-header">&#9670; Changelog</div>
                      <div class="panel-body">
                          <div class="changelog">
                           <div class="log-entry">
                            <div class="log-date">April 15th, 2026</div>
                            <div class="log-title">user comments</div>
                            <div class="log-desc">we have user comments now! sorry that we're becoming such of a social media almost, but it was requested. <br> i mean we got plants vs zombies (the real deal) now if y'all want to play it but idk have fun <3 ~ aj<br></div>
                            <span class="tag tag-new">new</span>
                          </div>
                            <div class="log-entry">
                            <div class="log-date">April 13th, 2026</div>
                            <div class="log-title">user profiles and new domain!</div>
                            <div class="log-desc">we are now up at <a href="https://wavelength.rip" target="_blank">wavelength.rip</a> (thanks to thatoneperson!) + we have user profiles now for y'all that requested it! have fun <3 ~ aj<br> (the domain cost $5 this year and it's going to be $20 the next so donate pretty please)</div>
                            <span class="tag tag-new">new</span>
                          </div>
                          <div class="log-entry">
                            <div class="log-date">April 12th, 2026</div>
                            <div class="log-title">added terraria and stardew valley</div>
                            <div class="log-desc">uh yeah very swag, have fun! ~ aj</div>
                            <span class="tag tag-new">new</span>
                          </div>
                          <div class="log-entry">
                            <div class="log-date">April 10th, 2026 - 3:08pm</div>
                            <div class="log-title">added user accounts</div>
                            <div class="log-desc">y'all can login and chat with your own accounts! <br> any vulgar account names will be deleted and by default you will be in as a guest, no account linked <br> otherwise have fun! ~ aj</div>
                            <span class="tag tag-new">new</span>
                          </div>
                            <div class="log-entry">
                            <div class="log-date">April 10th, 2026 - 12:27pm</div>
                            <div class="log-title">make game buttons bigger</div>
                            <div class="log-desc">some of y'all don't know how to read so the buttons to make the games open in fullscreen are *bigger* now ~ aj</div>
                            <span class="tag tag-fix">fix</span>
                          </div>
                            <div class="log-entry">
                            <div class="log-date">April 9, 2026</div>
                            <div class="log-title">Fixed chat/added moderation</div>
                            <div class="log-desc">So turns out yall like bad words too much so there banned now ~ Itz_Kire</div>
                            <span class="tag tag-fix">Fix</span>
                          </div>
                             <div class="log-entry">
                                  <div class="log-date">April 6, 2026</div>
                                  <div class="log-title">added cdn switch</div>
                                  <div class="log-desc">githack gets blocked at some schools so we have multiple cdn's to fetch from! ~ aj</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                            <div class="log-entry">
                                  <div class="log-date">April 5, 2026</div>
                                  <div class="log-title">added more ports</div>
                                  <div class="log-desc">yeah uh some more web ports are on the site, go have fun - aj</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                              <div class="log-entry">
                                  <div class="log-date">April 4, 2026</div>
                                  <div class="log-title">Added: Shop</div>
                                  <div class="log-desc">There is now a shop, albeit its not a shop, and it doesn't work yet</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                              <div class="log-entry">
                                    <div class="log-date">April 3, 2026</div>
                                  <div class="log-title">Added: GAMES</div>
                                  <div class="log-desc">Play your favorite games on wavelength!</div>
                                  <span class="tag tag-new">New</span>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
              <div class="dmca-footer">
                <button class="win-btn dmca-footer-btn" onclick="document.getElementById('dmca-modal').style.display='flex'">[ dmca ]</button>
              </div>
            </div>

            <div id="tab-games" class="tab-panel">

              <div id="games-list-view">
                <div id="games-popular-section" class="games-popular-section" hidden>
                  <div class="games-popular-heading-row">
                    <div class="games-popular-heading">[ popular games ]</div>
                    <div id="games-popular-hint" class="games-popular-hint" hidden>&larr; scroll &rarr;</div>
                  </div>
                  <div id="games-popular-list" class="games-popular-list"></div>
                </div>
                <div class="games-controls">
                  <div class="games-filters">
                    <button class="games-filter-btn active" data-filter="all">All</button>
                    <button class="games-filter-btn" data-filter="html">HTML5</button>
                    <button class="games-filter-btn" data-filter="ruffle">Flash</button>
                    <button class="games-filter-btn" data-filter="webPorts">Web Ports</button>
                  </div>
                  <div class="games-search-row">
                    <input type="search" id="games-search" class="games-search-input" placeholder="Search games..." />
                    <select id="games-sort" class="games-sort-select">
                      <option value="alpha-asc">A → Z</option>
                      <option value="alpha-desc">Z → A</option>
                    </select>
                  </div>
                </div>
                <div id="games-grid" class="games-grid">
                  <div id="games-sentinel" class="games-sentinel"></div>
                </div>
                <div id="games-status" class="games-status"></div>
              </div>

              <div id="games-play-view" style="display:none;">
                <button class="back-btn win-btn" onclick="closeGame()">back</button>

                  <div class="cdn-switcher-row">
                  <span class="cdn-switcher-row-label">CDN:</span>
                  <div id="cdn-switcher"></div>
                  <span class="cdn-indicator-wrap">active: <span id="cdn-indicator">jsDelivr</span></span>
                </div>

                <div class="play-view-inner">
                  <div class="iframe-container">
                    <iframe id="game-iframe" class="gameframe" allowfullscreen
                      sandbox="allow-scripts allow-same-origin allow-forms allow-pointer-lock allow-top-navigation"></iframe>
                  </div>
                </div>

                <div class="iframe-buttons">
                  <button class="win-btn" onclick="openCloaked()">fullscreen (new tab)</button>
                  <button class="win-btn" onclick="credits()">game credits</button>
                </div>
              </div>

            </div>

            <div id="tab-chat" class="tab-panel">

              <div id="username-modal" class="modal-overlay" style="display:none;">
                <div class="modal-box">
                  <button class="modal-close-btn" onclick="closeUsernameModal()" aria-label="Close username dialog">x</button>
                  <div class="panel-header">&#9670; Join Chat</div>
                  <div class="panel-body" style="padding:12px;">
                    <p style="font-size:12px;margin-bottom:8px;">Choose a username:</p>
                    <input id="username-input" class="chat-input-field" type="text" maxlength="20" placeholder="your_name_here..."
                      onkeydown="if(event.key==='Enter')joinChat()">
                    <div id="username-error" style="color:#ff6b6b;font-size:11px;min-height:16px;margin-top:4px;"></div>
                    <div style="margin-top:8px;">
                      <button class="win-btn" onclick="joinChat()">[ JOIN ]</button>
                    </div>
                  </div>
                </div>
              </div>

              <div id="chat-ui" style="display:none;">
                <div class="panel">
                  <div class="panel-header">
                    &#9670; Chat &nbsp;<span id="chat-user-label" style="font-weight:normal;font-size:10px;opacity:0.85;"></span>
                    <span id="chat-link-status" style="font-weight:normal;font-size:10px;opacity:0.85;margin-left:8px;"></span>
                    <button id="chat-link-btn" onclick="linkChatToAccount()" class="win-btn" style="display:none;font-size:9px; margin-left:10px; padding: 2px 5px;">[ LINK ACCOUNT ]</button>
                    <button id="chat-timeout-btn" onclick="timeoutUserByName()" class="win-btn" style="display:none;font-size:9px; margin-left:10px; padding: 2px 5px;">[ TIMEOUT USER ]</button>
                    <button onclick="changeUsername()" class="win-btn" style="font-size:9px; margin-left:10px; padding: 2px 5px;">[ CHANGE NAME ]</button>
                  </div>
                  <div class="panel-body" style="padding:0;display:flex;flex-direction:column;height:68vh;">
                    <div id="chat-messages" class="chat-messages"></div>
                    <div class="chat-footer">
                      <input id="chat-msg-input" class="chat-input-field" type="text" maxlength="500"
                        placeholder="type a message and press Enter..."
                        onkeydown="if(event.key==='Enter')sendMessage()">
                      <button class="win-btn" onclick="sendMessage()">[ SEND ]</button>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <div id="tab-users" class="tab-panel">
              <div class="users-layout">
                <div class="panel">
                  <div class="panel-header">&#9670; Account</div>
                  <div class="panel-body users-auth-body">
                    <div id="users-auth-status" class="users-auth-status">Not logged in.</div>

                    <div id="users-auth-message" class="users-auth-message"></div>

                    <div id="users-auth-forms">
                      <div class="users-auth-group">
                        <label for="users-register-name">Username</label>
                        <input id="users-register-name" class="chat-input-field" type="text" maxlength="24" placeholder="your_name_here...">
                      </div>
                      <div class="users-auth-group">
                        <label for="users-register-password">Password</label>
                        <input id="users-register-password" class="chat-input-field" type="password" maxlength="72" placeholder="at least 6 characters">
                      </div>
                      <div class="users-auth-actions">
                        <button class="win-btn" onclick="registerUser()">[ REGISTER ]</button>
                        <button class="win-btn" onclick="loginUser()">[ LOGIN ]</button>
                      </div>
                    </div>

                    <div id="users-auth-logged-in" style="display:none;">
                      <div class="users-auth-hello" id="users-auth-hello"></div>
                      <div class="users-auth-actions">
                        <button class="win-btn" onclick="openProfileSettings()">[ SETTINGS ]</button>
                        <button class="win-btn" onclick="openMyProfile()">[ VIEW PROFILE ]</button>
                        <button class="win-btn" onclick="logoutUser()">[ LOG OUT ]</button>
                      </div>
                    </div>

                    <div id="users-settings" class="users-settings" style="display:none;">
                      <div class="users-settings-title">Customize your profile</div>

                      <div class="users-auth-group">
                        <label for="profile-display-name">Display name</label>
                        <input id="profile-display-name" class="chat-input-field" type="text" maxlength="40" placeholder="how your profile name appears">
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-pronouns">Pronouns</label>
                        <input id="profile-pronouns" class="chat-input-field" type="text" maxlength="40" placeholder="e.g. he/him, she/her, they/them">
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-song-url">Background song (YouTube or Direct Audio Link)</label>
                        <input id="profile-song-url" class="chat-input-field" type="url" maxlength="300" placeholder="https://youtube.com/... or https://site.com/song.mp3">
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-song-title">Song title</label>
                        <input id="profile-song-title" class="chat-input-field" type="text" maxlength="80" placeholder="Track name shown on your profile player">
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-song-artist">Song artist</label>
                        <input id="profile-song-artist" class="chat-input-field" type="text" maxlength="80" placeholder="Artist name shown on your profile player">
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-image-url">Profile image URL (requires approval)</label>
                        <input id="profile-image-url" class="chat-input-field" type="url" maxlength="500" placeholder="https://example.com/avatar.png">
                        <div id="profile-image-request-status" class="users-profile-hint"></div>
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-bio">Bio / About</label>
                        <textarea id="profile-bio" class="users-profile-textarea" maxlength="280" placeholder="write something about yourself..."></textarea>
                      </div>

                      <div class="users-auth-group">
                        <label>Profile buttons</label>
                        <div id="profile-button-picker" class="users-profile-button-picker"></div>
                        <div class="users-profile-hint">Choose up to 12 buttons from the assets/buttons folder.</div>
                      </div>

                      <div class="users-auth-group">
                        <label for="profile-theme-preset">Profile theme</label>
                        <select id="profile-theme-preset" class="chat-input-field" onchange="applyProfileThemePreset()">
                          <option value="classic">Classic</option>
                          <option value="pydra-light">The Pydra Project (Light)</option>
                          <option value="pydra-dark">The Pydra Project (Dark)</option>
                          <option value="sunset">Sunset</option>
                          <option value="matrix">Matrix</option>
                          <option value="midnight">Midnight</option>
                          <option value="bliish">Bliish</option>
                        </select>
                      </div>

                      <div class="users-auth-group">
                        <label>Theme colors (optional)</label>
                        <div class="users-theme-grid">
                          <label for="profile-theme-accent">Accent</label>
                          <input id="profile-theme-accent" class="users-color-input" type="color" value="#000080">
                          <label for="profile-theme-bg-start">Background top</label>
                          <input id="profile-theme-bg-start" class="users-color-input" type="color" value="#f8f8f8">
                          <label for="profile-theme-bg-end">Background bottom</label>
                          <input id="profile-theme-bg-end" class="users-color-input" type="color" value="#e5e5e5">
                          <label for="profile-theme-text">Text</label>
                          <input id="profile-theme-text" class="users-color-input" type="color" value="#000000">
                          <label for="profile-theme-text-muted">Muted text</label>
                          <input id="profile-theme-text-muted" class="users-color-input" type="color" value="#444444">
                          <label for="profile-theme-panel-bg">Panel background</label>
                          <input id="profile-theme-panel-bg" class="users-color-input" type="color" value="#ffffff">
                          <label for="profile-theme-bar">Top bar color</label>
                          <input id="profile-theme-bar" class="users-color-input" type="color" value="#000080">
                        </div>
                        <div class="users-profile-hint">Choose a preset, then fine-tune colors if you want.</div>
                        <button class="win-btn" type="button" onclick="resetProfileThemeColors()">[ RESET COLORS TO PRESET ]</button>
                      </div>

                      <div class="users-auth-actions">
                        <button class="win-btn" onclick="saveProfileSettings()">[ SAVE ]</button>
                        <button class="win-btn" onclick="closeProfileSettings()">[ CLOSE ]</button>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="panel">
                  <div class="panel-header">&#9670; Registered Users</div>
                  <div class="panel-body">
                    <div id="users-list-status" class="users-list-status">Loading users...</div>
                    <div id="users-list" class="users-list"></div>
                  </div>
                </div>
              </div>
            </div>

            <div id="tab-profile" class="tab-panel">
              <div class="panel">
                <div class="panel-header">&#9670; User Profile</div>
                <div class="panel-body">
                  <div id="profile-status" class="users-list-status">Select a user from the users list.</div>
                  <div id="profile-view" class="profile-view" style="display:none;">
                    <div class="profile-card">
                      <div class="profile-card-header">
                        <div class="profile-identity-wrap">
                          <div class="profile-avatar-wrap" aria-hidden="true">
                            <img id="profile-avatar-view" class="profile-avatar" alt="Profile avatar">
                            <div id="profile-avatar-fallback" class="profile-avatar-fallback">?</div>
                          </div>
                          <div>
                            <div class="profile-display-name" id="profile-display-name-view">Unknown</div>
                            <div class="profile-username" id="profile-username-view">@unknown</div>
                            <div class="profile-badges" id="profile-badges-view"></div>
                          </div>
                        </div>
                        <div class="profile-pronouns" id="profile-pronouns-view"></div>
                      </div>

                      <div id="profile-image-note-view" class="users-profile-hint" style="display:none;"></div>

                      <div class="profile-bio" id="profile-bio-view"></div>
                      <div class="profile-buttons" id="profile-buttons-view"></div>

                      <div class="profile-links" id="profile-links"></div>

                      <div id="profile-song-player-wrap" class="profile-song-player-wrap" style="display:none;">
                        <iframe id="profile-song-player" class="profile-song-player" allowfullscreen title="Profile song player" style="display:none;"></iframe>

                        <div id="retro-audio-skin" class="win95-media-player" style="display:none;">
                          <div class="player-titlebar">
                            <span class="player-title-text">Windows Media Player</span>
                            <div class="player-title-buttons" aria-hidden="true">
                              <span class="title-btn-glyph">_</span>
                              <span class="title-btn-glyph">&#9633;</span>
                              <span class="title-btn-glyph">&#10005;</span>
                            </div>
                          </div>
                          <div class="player-body">
                            <div class="player-display">
                              <div id="audio-status-text" class="status-marquee">READY</div>
                            </div>
                            <div class="player-meta-grid">
                              <div class="player-meta-row">
                                <span class="player-meta-label">Song:</span>
                                <span id="audio-song-name" class="player-meta-value">Unknown Track</span>
                              </div>
                              <div class="player-meta-row">
                                <span class="player-meta-label">Artist:</span>
                                <span id="audio-artist-name" class="player-meta-value">Unknown Artist</span>
                              </div>
                            </div>
                            <div class="player-time-row">
                              <span id="audio-time-current">0:00</span>
                              <span id="audio-time-duration">0:00</span>
                            </div>
                            <div class="player-progress-track" aria-hidden="true">
                              <div id="audio-progress-fill" class="player-progress-fill"></div>
                            </div>
                            <div class="player-timestamps">
                              <span id="audio-timestamp-start">00:00</span>
                              <span id="audio-timestamp-end">00:00</span>
                            </div>
                            <div class="player-controls">
                              <button id="profile-audio-play-btn" class="win-btn-small" type="button"><span>&#9654; Play</span></button>
                              <button id="profile-audio-stop-btn" class="win-btn-small" type="button"><span>&#9632; Stop</span></button>
                              <button id="profile-audio-loop-btn" class="win-btn-small" type="button" aria-pressed="true" title="Toggle loop"><span id="profile-audio-loop-icon">Loop</span></button>
                            </div>
                          </div>
                          <audio id="profile-audio-player" style="display:none;"></audio>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- ── Profile Comments ── -->
              <div id="profile-comments-section" class="panel" style="margin-top:12px;display:none;">
                <div class="panel-header">&#9670; Comments</div>
                <div class="panel-body" style="padding:12px;">
                  <div id="profile-comments-list" class="profile-comments-list"></div>
                  <div id="profile-comments-auth-hint" class="users-profile-hint" style="margin-top:8px;"></div>
                  <div id="profile-comment-form" style="display:none;margin-top:10px;">
                    <textarea id="profile-comment-input" class="users-profile-textarea" maxlength="300"
                      placeholder="leave a comment..." style="height:60px;"></textarea>
                    <div style="margin-top:6px;">
                      <button class="win-btn" onclick="submitProfileComment()">[ POST ]</button>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <div id="tab-shop" class="tab-panel">
              <div class="panel">
                <div class="panel-header">&#9670; Shop</div>
                <div class="panel-body shop-body">
                  <div class="shop-text">
                    <p>Wavelength will always be free to play.</p>
                    <p>If you wish to support us, feel free to donate<br>to our side project Pydra!</p>
                    <p>if you wish to donate using crypto, please email<br><span class="shop-xmr">support@pydra.dev</span>.</p>
                  </div>
                  <div class="shop-logo-wrap">
                    <a href="https://hcb.hackclub.com/donations/start/pydra" target="_blank">
                      <img src="https://pydra.dev/favicon.png" alt="Pydra" class="shop-pydra-logo">
                      <div class="shop-logo-label">click on me!</div>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <div id="tab-credits" class="tab-panel">
              <div class="credits-title">~ credits ~</div>
              <div class="credits-section">
                  <div class="section-header">Main Developers</div>
                  <div class="credit-grid">
                    <a href="https://github.com/ajtabjs" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">aj</span></div>
                    </a>
                    <a href="https://github.com/ThatOnePers0n" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">ThatOnePers0n</span></div>
                    </a>
                    <a href="https://github.com/ki-krpto" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">its_kirè</span></div>
                    </a>
                    <a href="https://github.com/MinoDab492" target="_blank">
                      <div class="credit-entry"><span class="dot dot-orange"></span><span class="name-orange">MinoDab492</span></div>
                    </a>
                  </div>
              </div>
              <hr class="credits-divider">
              <div class="credits-section">
                  <div class="section-header">Game Sources</div>
                  <div class="credit-grid">
