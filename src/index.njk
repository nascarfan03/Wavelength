    {# ═══════════════════════════════════════════════════════════════════
       ELEVENTY INJECTS GAME DATA HERE AT BUILD TIME
       Edit _data/htmlGames.json, ruffleGames.json, or webPorts.json to add games!
       Edit _data/popularGames.json to control the popular games row.
       Drop jsdelivrUrls.json and githackUrls.json in _data/ too.
       ═══════════════════════════════════════════════════════════════════ #}
    <script>
      window.__BASE_URLS__     = {{ statically | dump | safe }};
      window.__JSDELIVR_URLS__ = {{ jsdelivr | dump | safe }};
      window.__GITHACK_URLS__  = {{ githack | dump | safe }};
      window.__CREDITS_MAPPING__ = {{ creditsMapping | dump | safe }};
      window.__BADGE_CONFIG__ = {{ profileBadges | dump | safe }};
      window.__PROFILE_BUTTON_ASSETS__ = {{ profileButtons | dump | safe }};
      window.__POPULAR_GAMES__ = {{ popularGames | dump | safe }};
      window.__GAMES_DATA__ = [
        {% for g in htmlGames %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "html"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
        {% for g in ruffleGames %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "ruffle"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
        {% for g in webPorts %}
          { "name": {{ g.name | dump | safe }}, "slug": {{ g.slug | dump | safe }}, "path": {{ g.path | dump | safe }}, "thumbnail": {{ g.thumbnail | dump | safe }}, "description": {{ g.description | dump | safe }}, "type": "webPorts"{% if g.cdn %}, "cdn": {{ g.cdn | dump | safe }}{% endif %} },
        {% endfor %}
      ];
    </script>

    <script src="games-loader.js"></script>
    <script src="site.js" type="module"></script>
    <script src="mirror.js"></script>

</body>
